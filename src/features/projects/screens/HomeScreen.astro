---
import Heading from '@/components/Heading.astro';
import SkillCard from '@/components/SkillCard.astro';
import { buttonVariants } from '@/components/ui/button';
import type { LanguageCode } from '@/i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { Calendar, Dumbbell } from 'lucide-react';
import { FaLinkedinIn, FaGithub, FaMedium } from 'react-icons/fa';
import heroImage from '@/assets/user-hero.webp';
import { Image } from 'astro:assets';
import FeaturedProjectPreview from '../components/FeaturedProjectPreview.astro';
import type { TranslatedProject, TranslatedSkill } from '../type';

export type Props = {
  lang: LanguageCode;
  projects: Array<TranslatedProject>;
  skills: Array<TranslatedSkill>;
  heroGreeting: string;
  heroSubtitlePart1: string;
  heroSubtitlePart2: string;
  heroIntroduction: string;
  heroViewWorkButton: string;
  heroContactButton: string;
  imageNotAvailable: string;
  featuredProjectsTitle: string;
  featuredProjectsDescription: string;
  mySkillsTitle: string;
  mySkillsDescription: string;
  projectPreviewCtaText: string;
};

const {
  lang,
  projects,
  skills,
  heroViewWorkButton,
  heroContactButton,
  featuredProjectsTitle,
  featuredProjectsDescription,
  mySkillsTitle,
  mySkillsDescription,
  projectPreviewCtaText,
} = Astro.props;

const socials = [
  { href: 'https://linkedin.com/in/nicholas-hong001', label: 'LinkedIn', Icon: FaLinkedinIn },
  { href: 'https://github.com/Nicholashsw', label: 'GitHub', Icon: FaGithub },
  { href: 'https://medium.com/@nhong001', label: 'Medium', Icon: FaMedium },
];
---

{/* Hero */}
<section class="py-12 md:py-16 relative overflow-hidden">
  {/* warm gold glow */}
  <div
    class="pointer-events-none absolute -top-32 -left-24 h-[460px] w-[600px] rounded-full bg-[#c9a84c]/20 blur-[130px] -z-10"
  >
  </div>
  <div class="grid md:grid-cols-2 gap-12 items-center relative z-10">
    {/* Hero Text */}
    <div class="text-center md:text-left">
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-6 bg-gradient-to-br from-foreground via-foreground to-[#e8c97a] bg-clip-text text-transparent"
      >
        Hi, I'm Nicholas 👋
      </h1>
      <p class="text-xl md:text-2xl font-medium text-muted-foreground mb-4">
        <span class="text-foreground/90">Quant researcher &amp; engineer</span>
        <span class="text-primary mx-2">|</span>
        <span class="text-foreground/90">Data, markets &amp; code</span>
      </p>
      <p
        class="text-lg text-muted-foreground mb-8 max-w-2xl mx-auto md:mx-0 leading-relaxed"
      >
        I design and test systematic trading strategies — Always refining,
        always iterating.
      </p>
      <div
        class="flex flex-col sm:flex-row gap-5 justify-center md:justify-start mb-6"
      >
        <a
          href="/projects"
          class={buttonVariants({ variant: 'default', size: 'lg', className: 'shadow-lg shadow-primary/20 hover:-translate-y-1 transition-transform' })}
        >
          <Dumbbell className="mr-2 size-5" />
          {heroViewWorkButton}
        </a>
        <a
          href={getRelativeLocaleUrl(lang, '/contact')}
          class={buttonVariants({ variant: 'outline', size: 'lg', className: 'hover:bg-muted/50 hover:-translate-y-1 transition-transform' })}
        >
          <Calendar className="mr-2 size-5" />
          {heroContactButton}
        </a>
      </div>
      <div class="flex gap-3 justify-center md:justify-start">
        {
          socials.map(({ href, label, Icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener"
              aria-label={label}
              class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border/60 bg-muted/30 text-muted-foreground transition-colors hover:border-primary/50 hover:bg-primary/10 hover:text-primary"
            >
              <Icon className="size-[18px]" />
            </a>
          ))
        }
      </div>
    </div>
    {/* Hero Image */}
    <div class="flex justify-center md:justify-end mt-12 md:mt-0">
      <div
        class="w-full max-w-[440px] aspect-square rounded-2xl shadow-2xl shadow-primary/10 overflow-hidden border border-border/50 bg-muted/30 hover:scale-[1.02] transition-all duration-500"
      >
        <Image
          src={heroImage}
          alt="Nicholas Hong"
          width={600}
          height={600}
          loading="eager"
          densities={[1, 1.5, 2]}
          quality="high"
          class="h-full w-full object-cover object-center"
        />
      </div>
    </div>
  </div>
</section>

{/* Featured Projects */}
<section
  id="projects"
  class="py-16 md:py-24 my-12 rounded-[2.5rem] bg-gradient-to-b from-muted/30 to-muted/10 border border-border/50 shadow-sm relative overflow-hidden px-6 md:px-12"
>
  <Heading
    title={featuredProjectsTitle}
    description={featuredProjectsDescription}
    className="mb-12 relative z-10"
  />
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {
      projects.slice(0, 3).map((project: TranslatedProject) => (
        <FeaturedProjectPreview
          lang={lang}
          slug={project.slug}
          title={project.title}
          imageUrl={project.imageUrl}
          imageAltText={project.imageAltText}
          ctaText={projectPreviewCtaText}
        />
      ))
    }
  </div>
</section>

{/* Skills */}
<section id="skills" class="py-16 md:py-24 relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <Heading
      title={mySkillsTitle}
      description={mySkillsDescription}
      className="mb-12"
    />
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        skills.map((skill) => (
          <SkillCard
            title={skill.title}
            description={skill.description}
            iconName={skill.iconName}
            technologies={skill.technologies}
          />
        ))
      }
    </div>
  </div>
</section>
